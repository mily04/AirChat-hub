{
  "name": "tmesh",
  "version": "0.0.0",
  "description": "Local network chat and file sharing for nearby devices.",
  "license": "AGPL-3.0-or-later",
  "author": "mily04 <mily040625@gmail.com>",
  "homepage": "https://github.com/mily04/AirChat-hub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mily04/AirChat-hub.git"
  },
  "bugs": {
    "url": "https://github.com/mily04/AirChat-hub/issues"
  },
  "keywords": [
    "lan",
    "chat",
    "file-sharing",
    "socket.io",
    "react",
    "vite",
    "typescript"
  ],
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node -e \"process.env.NODE_ENV='production'; import('./dist/server.js')\"",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.js",
    "build:exe-server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=bundle --external:vite --outfile=dist/server.cjs",
    "package:win": "npm run build && npm run build:exe-server && pkg . --targets node18-win-x64 --output dist/Tmesh.exe",
    "package:mac": "npm run build && electron-builder --mac dmg",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.mily04.tmesh",
    "productName": "Tmesh",
    "copyright": "Copyright © 2026 mily04",
    "asar": true,
    "icon": "build/icon",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.icns",
      "build/icon.png",
      "package.json",
      "LICENSE",
      "LICENSE-COMMERCIAL.md",
      "THIRD_PARTY_LICENSES.md"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "release"
    }
  },
  "bin": "dist/server.cjs",
  "pkg": {
    "assets": [
      "dist/index.html",
      "dist/assets/**/*"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bonjour-service": "^1.3.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "js-sha256": "^0.11.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tweetnacl": "^1.0.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.21",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
